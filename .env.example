# Copy this file to .env.local and fill in the values.
# Only VITE_-prefixed vars are exposed to the browser bundle — never put
# secrets (service role key, API secrets, OAuth secrets) behind a VITE_ prefix.

# --- Supabase (required for Phase 1) ---
# API settings: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (Phase 4+ email import / admin tasks). Do NOT prefix VITE_.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
VITE_APP_URL=            # used for share-link generation (Phase 6)

# --- Anthropic Claude API (Phase 4 — email parsing) ---
ANTHROPIC_API_KEY=

# --- FlightAware AeroAPI (Phase 5 — flight status) ---
AEROAPI_KEY=

# --- Google OAuth / Gmail (Phase 4 — email import) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=       # e.g. http://localhost:3000/api/gmail/callback (local)
                           #      https://<your-app>/api/gmail/callback (prod)

# Random secret used to sign the OAuth `state` param (Phase 4). Generate with:
#   node -e "console.log(crypto.randomUUID() + crypto.randomUUID())"
OAUTH_STATE_SECRET=
